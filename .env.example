# Copy this file to .env in the repository root.
OPENAI_API_KEY=your_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
# OpenAI-compatible gateways can use their own /v1 base URL, for example:
# OPENAI_BASE_URL=https://api.bupt8.com/v1
# Use chat_completions if a gateway does not support /v1/responses.
OPENAI_COMPAT_API=responses
AI_TEXT_PROVIDER=openai
AI_REALTIME_PROVIDER=openai
OPENAI_MODEL=gpt-5-mini
OPENAI_PM_MODEL=gpt-5-mini
OPENAI_BOARD_MODEL=gpt-5-mini
OPENAI_GUIDE_MODEL=gpt-5-mini
OPENAI_TEACHER_MODEL=gpt-5-mini
OPENAI_LESSON_MODEL=gpt-5-mini
# Optional: uncomment to use a separate official OpenAI key/base URL for Realtime while text uses a gateway.
# OPENAI_REALTIME_API_KEY=your_openai_realtime_key_here
OPENAI_REALTIME_BASE_URL=https://api.openai.com/v1
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_VOICE=marin
# Auto-discover selectable OpenAI-compatible models from OPENAI_BASE_URL/models.
AI_MODEL_DISCOVERY_ENABLED=true
# Optional manual additions when a gateway hides models from /models.
# AI_TEXT_MODELS_JSON=[{"provider":"openai","model":"gpt-5.4","label":"GPT-5.4"}]
# AI_REALTIME_MODELS_JSON=[{"provider":"openai","model":"gpt-4o-realtime-preview","label":"GPT-4o Realtime","transport":"openai_webrtc"}]

ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-opus-4-7

GOOGLE_API_KEY=your_google_gemini_key_here
GOOGLE_TEXT_MODEL=gemini-3.1-pro-preview
GOOGLE_REALTIME_MODEL=gemini-3.1-flash-live-preview
GOOGLE_REALTIME_VOICE=Aoede

# Official OpenAI-compatible providers.
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

KIMI_API_KEY=your_kimi_key_here
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6

MINIMAX_API_KEY=your_minimax_key_here
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7

# Custom OpenAI-compatible provider.
OPENAI_COMPATIBLE_API_KEY=your_custom_openai_compatible_key_here
OPENAI_COMPATIBLE_BASE_URL=https://your-openai-compatible-host/v1
OPENAI_COMPATIBLE_MODEL=gpt-5-mini
OPENAI_COMPATIBLE_COMPAT_API=chat_completions

# Custom Anthropic-compatible provider.
ANTHROPIC_COMPATIBLE_API_KEY=your_custom_anthropic_compatible_key_here
ANTHROPIC_COMPATIBLE_BASE_URL=https://your-anthropic-compatible-host
ANTHROPIC_COMPATIBLE_MODEL=claude-opus-4-7

# Copy this file to .env in the repository root.
#
# === 环境变量索引（详细变量见下方分组） ===
# 运行与存储
#   OPENCLASS_DATABASE_PATH — SQLite 主库（生产必设持久化目录）
#   OPENCLASS_UPLOAD_DIR / OPENCLASS_EXPORT_DIR — 上传与导出落盘目录
#   OPENCLASS_PUBLIC_ORIGIN / OPENCLASS_WEB_ORIGIN — 对外 URL（OAuth 回调、邮件链接）
# 认证与邮件
#   OPENCLASS_ADMIN_EMAILS — 额外管理员邮箱
#   OPENCLASS_EMAIL_DELIVERY — log（本地写日志）| smtp
#   OPENCLASS_SMTP_* — SMTP 发信配置
#   OPENCLASS_OAUTH_* — Google / GitHub / Apple 等 OAuth 客户端
# AI 文本与图像
#   OPENAI_API_KEY — OpenAI 官方 API
#   OPENAI_MODEL / OPENAI_*_MODEL — 各路由默认模型
#   AI_TEXT_PROVIDER / AI_REALTIME_PROVIDER — provider 选择
# Realtime 语音（默认关闭）
#   OPENCLASS_REALTIME_ENABLED / OPENCLASS_REALTIME_TOOLS_ENABLED
#   OPENAI_REALTIME_* / GOOGLE_REALTIME_* — 实时模型与音色
# 资料解析
#   OPENCLASS_RESOURCE_PARSER_* — 可选外部解析器
#   OPENCLASS_RESOURCE_EMBEDDINGS_ENABLED — 资料向量检索
# 其他 Provider
#   ANTHROPIC_* / DEEPSEEK_* / KIMI_* / MINIMAX_* / OPENAI_COMPATIBLE_* 等
#
# Local default is apps/api/data/openclass.sqlite3. Use a persistent absolute path in production.
# OPENCLASS_DATABASE_PATH=/var/lib/openclass/openclass.sqlite3
# OPENCLASS_UPLOAD_DIR=/var/lib/openclass/uploads
# OPENCLASS_EXPORT_DIR=/var/lib/openclass/exports
# OPENCLASS_PUBLIC_ORIGIN=https://open-classes.com
# OPENCLASS_WEB_ORIGIN=https://open-classes.com
# OPENCLASS_ADMIN_EMAILS=teacher@example.com
# OPENCLASS_AUTH_PUBLIC_PROVIDERS=google,github

# Transactional email for account verification and password reset.
# Local development can use OPENCLASS_EMAIL_DELIVERY=log to write links to apps/api/data/logs/email-delivery.jsonl.
# OPENCLASS_EMAIL_DELIVERY=smtp
# OPENCLASS_SMTP_HOST=smtp.example.com
# OPENCLASS_SMTP_PORT=587
# OPENCLASS_SMTP_USERNAME=your_smtp_username
# OPENCLASS_SMTP_PASSWORD=your_smtp_password
# OPENCLASS_SMTP_FROM="OpenClass <noreply@example.com>"
# OPENCLASS_SMTP_STARTTLS=true

# Optional account login providers. Redirect URI format:
# https://your-domain.com/api/auth/oauth/{provider}/callback
# OPENCLASS_OAUTH_GOOGLE_CLIENT_ID=your_google_oauth_client_id
# OPENCLASS_OAUTH_GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# OPENCLASS_OAUTH_APPLE_CLIENT_ID=your_apple_services_id
# OPENCLASS_OAUTH_APPLE_CLIENT_SECRET=your_apple_client_secret_jwt
# OPENCLASS_OAUTH_GITHUB_CLIENT_ID=your_github_oauth_client_id
# OPENCLASS_OAUTH_GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
# OPENCLASS_OAUTH_MICROSOFT_CLIENT_ID=your_microsoft_oauth_client_id
# OPENCLASS_OAUTH_MICROSOFT_CLIENT_SECRET=your_microsoft_oauth_client_secret
# OPENCLASS_OAUTH_X_CLIENT_ID=your_x_oauth_client_id
# OPENCLASS_OAUTH_X_CLIENT_SECRET=your_x_oauth_client_secret
OPENAI_API_KEY=your_openai_api_key_here
# Text, image, and OpenAI realtime calls use the official OpenAI API by default.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_COMPAT_API=chat_completions
AI_TEXT_PROVIDER=openai
AI_REALTIME_PROVIDER=openai
OPENAI_MODEL=gpt-5.5
# Interaction AI uses GPT-5.5 for text. Uploaded materials use deterministic parsing/navigation.
OPENAI_PM_MODEL=gpt-5.5
OPENAI_BOARD_MODEL=gpt-5.5
OPENAI_GUIDE_MODEL=gpt-5.5
OPENAI_CHATBOT_MODEL=gpt-5.5
OPENAI_LESSON_MODEL=gpt-5.5
OPENCLASS_RESOURCE_EMBEDDINGS_ENABLED=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: reduce stored vector size for resource segment retrieval.
# OPENAI_EMBEDDING_DIMENSIONS=512
# Optional external resource parser adapter. The command receives the uploaded file path
# as the final argument and may output raw text or JSON with text/markdown/blocks/pages/headings.
# OPENCLASS_RESOURCE_PARSER_COMMAND=/usr/local/bin/openclass-resource-parser
# OPENCLASS_RESOURCE_PARSER_TIMEOUT_SECONDS=180
# OPENCLASS_RESOURCE_PARSER=docling-wrapper
# OPENCLASS_RESOURCE_PARSER_VERSION=local
OPENCLASS_REALTIME_ENABLED=false
OPENCLASS_REALTIME_TOOLS_ENABLED=false
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
OPENAI_STRONG_REASONING_MODEL=gpt-5.5
OPENAI_STRONG_REASONING_EFFORT=high
OPENAI_PRO_REASONING_MODEL=gpt-5.5-pro
OPENCLASS_STRONG_REASONING_ALLOW_PRO=false
OPENAI_IMAGE_MODEL=gpt-image-2
# Optional image generation tuning for generated board charts.
# OPENAI_IMAGE_SIZE=1536x1024
# OPENAI_IMAGE_QUALITY=medium
# Optional manual additions for models not returned by /models.
# AI_TEXT_MODELS_JSON=[{"provider":"openai","model":"custom-text-model","label":"Custom Text"}]

GOOGLE_TEXT_MODEL=gemini-3-flash-preview
GOOGLE_REALTIME_MODEL=gemini-3.1-flash-live-preview
GOOGLE_REALTIME_VOICE=Aoede
# Google Gemini Live uses Google credentials, not the OpenAI API key above.
# Set one of these when AI_REALTIME_PROVIDER=google:
# GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# Optional provider-specific keys for non-OpenAI providers.
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# DEEPSEEK_API_KEY=your_deepseek_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash

# KIMI_API_KEY=your_kimi_key_here
# KIMI_BASE_URL=https://api.moonshot.ai/v1
# KIMI_MODEL=kimi-k2.6

# MINIMAX_API_KEY=your_minimax_key_here
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_MODEL=MiniMax-M2.7-highspeed

# OPENAI_COMPATIBLE_API_KEY=your_custom_openai_compatible_key_here
# OPENAI_COMPATIBLE_BASE_URL=https://your-openai-compatible-host/v1
# OPENAI_COMPATIBLE_MODEL=gpt-5.4-mini
# OPENAI_COMPATIBLE_COMPAT_API=chat_completions

# ANTHROPIC_COMPATIBLE_API_KEY=your_custom_anthropic_compatible_key_here
# ANTHROPIC_COMPATIBLE_BASE_URL=https://your-anthropic-compatible-host
# ANTHROPIC_COMPATIBLE_MODEL=claude-sonnet-4-6

# Copy this file to .env in the repository root.
# Local default is apps/api/data/openclass.sqlite3. Use a persistent absolute path in production.
# OPENCLASS_DATABASE_PATH=/var/lib/openclass/openclass.sqlite3
# OPENCLASS_UPLOAD_DIR=/var/lib/openclass/uploads
# OPENCLASS_EXPORT_DIR=/var/lib/openclass/exports
# OPENCLASS_PUBLIC_ORIGIN=https://class.bupt8.com
# OPENCLASS_WEB_ORIGIN=https://class.bupt8.com
# OPENCLASS_ADMIN_EMAILS=teacher@example.com
# Uploaded resource parser: auto uses RAG-Anything for supported complex files when available, then falls back to native.
# OPENCLASS_RESOURCE_PARSER=auto
# Defaults to ./RAG-Anything-main when present, then ../RAG-Anything-main. Override when needed.
# OPENCLASS_RAG_ANYTHING_PATH=RAG-Anything-main
# OPENCLASS_RAG_ANYTHING_PARSER=mineru
# OPENCLASS_RAG_ANYTHING_PARSE_METHOD=auto
# OPENCLASS_RAG_ANYTHING_OUTPUT_DIR=apps/api/data/raganything

# File/material backend. Native keeps original files, directory/body ranges, and local search in OpenClass.
OPENCLASS_SOURCE_BACKEND=native
# native: local text-first parsing, PDF outline/EPUB navigation indexing, and scoped search.
# open_notebook: optional external OpenNotebook-owned parsing, indexing, status, and search.
# OPEN_NOTEBOOK_API_URL=http://localhost:5055
# OPEN_NOTEBOOK_API_PREFIX=/api
# OPEN_NOTEBOOK_PASSWORD=
# OPEN_NOTEBOOK_TIMEOUT_SECONDS=20
# Deterministic directory parsing is authoritative.
OPENCLASS_SOURCE_VISUAL_INDEX_ENABLED=false
OPENCLASS_MEDIA_INGESTION_ENABLED=false
OPENCLASS_MEDIA_MAX_BYTES=2147483648
OPENCLASS_MEDIA_MAX_DURATION_SECONDS=14400
OPENCLASS_MEDIA_MAX_VIDEO_HEIGHT=720
OPENCLASS_MEDIA_FAILED_CACHE_HOURS=24
OPENCLASS_MEDIA_MAX_COARSE_FRAMES=480
OPENCLASS_MEDIA_MAX_VISION_FRAMES=96
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# Optional absolute binary paths; bundled ffmpeg is used when available.
# OPENCLASS_FFMPEG_PATH=/absolute/path/to/ffmpeg
# OPENCLASS_FFPROBE_PATH=/absolute/path/to/ffprobe
# YouTube requires yt-dlp-ejs plus a supported JavaScript runtime. Browser
# authorization is local/trusted only and still requires an explicit per-import opt-in.
OPENCLASS_YOUTUBE_JS_RUNTIME=node
# OPENCLASS_YOUTUBE_JS_RUNTIME_PATH=/absolute/path/to/node
OPENCLASS_YOUTUBE_BROWSER_AUTH_ENABLED=false
OPENCLASS_YOUTUBE_BROWSER=chrome
# OPENCLASS_YOUTUBE_BROWSER_PROFILE=Default
# Prefer an OS-protected secret mount in server deployments. Never commit this file.
# OPENCLASS_YOUTUBE_COOKIE_FILE=/absolute/path/to/youtube-cookies.txt
# Optional local ASR provider. Install with: pip install -e '.[media-local]'
OPENCLASS_LOCAL_TRANSCRIPTION_PROVIDER=auto
OPENCLASS_DEFAULT_TRANSCRIPTION_PROVIDER=openclass_local
# Optional override; auto defaults to mlx-community/whisper-small-mlx on Apple Silicon
# or the faster-whisper small model elsewhere.
# OPENCLASS_LOCAL_TRANSCRIPTION_MODEL=mlx-community/whisper-small-mlx
# OPENCLASS_LOCAL_TRANSCRIPTION_PYTHON=/absolute/path/to/python
OPENCLASS_LOCAL_TRANSCRIPTION_TIMEOUT_SECONDS=3600

# Optional account login providers. Redirect URI format:
# https://your-domain.com/api/auth/oauth/{provider}/callback
# OPENCLASS_OAUTH_GOOGLE_CLIENT_ID=your_google_oauth_client_id
# OPENCLASS_OAUTH_GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# OPENCLASS_OAUTH_APPLE_CLIENT_ID=your_apple_services_id
# OPENCLASS_OAUTH_APPLE_CLIENT_SECRET=your_apple_client_secret_jwt
# OPENCLASS_OAUTH_GITHUB_CLIENT_ID=your_github_oauth_client_id
# OPENCLASS_OAUTH_GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
# OPENCLASS_OAUTH_MICROSOFT_CLIENT_ID=your_microsoft_oauth_client_id
# OPENCLASS_OAUTH_MICROSOFT_CLIENT_SECRET=your_microsoft_oauth_client_secret
# OPENCLASS_OAUTH_X_CLIENT_ID=your_x_oauth_client_id
# OPENCLASS_OAUTH_X_CLIENT_SECRET=your_x_oauth_client_secret
# Codex is the Studio chat and document agent on the codexclass branch.
# This uses the official `codex app-server` device-code login flow. It is intended for
# local/trusted OpenClass workspaces, not multi-tenant server-side impersonation.
OPENCLASS_CODEX_APP_SERVER_ENABLED=true
# Explicitly allow ChatGPT device login to create or link an OpenClass account.
# Keep this false on multi-tenant deployments; Settings can still connect Codex separately.
OPENCLASS_CHATGPT_PLATFORM_LOGIN_ENABLED=false
# OPENCLASS_CODEX_CLI_PATH=/absolute/path/to/codex
# Absolute Poppler root containing bin/pdfinfo, bin/pdftotext, and bin/pdftoppm.
# PDF Source Codex tasks fail before model execution when this toolchain is unavailable.
# OPENCLASS_POPPLER_ROOT=/absolute/path/to/poppler
# Keep Codex auth/session data and isolated one-file board workspaces outside the repository.
# OPENCLASS_CODEX_HOME=~/.openclass/codex
# OPENCLASS_CODEX_WORKSPACE_ROOT=~/.openclass/codex-workspaces
# OPENCLASS_CODEX_BOARD_MAX_BYTES=2097152
# OPENAI_CODEX_MODEL=gpt-5.5

# OpenAI Realtime voice and text. The standard API key stays on the backend.
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENCLASS_REALTIME_ENABLED=false
OPENCLASS_REALTIME_TOOLS_ENABLED=true
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_REASONING_EFFORT=low
# OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-transcribe

# Shared DeepSeek text provider. One backend key is available to guest, user, and admin roles.
# OpenClass does not enforce a per-user DeepSeek balance or call limit; upstream provider limits
# and the account's actual billing still apply. Keep this key only on the backend.
# DEEPSEEK_API_KEY=your_deepseek_api_key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_TIMEOUT_SECONDS=120
# DEEPSEEK_MAX_TOKENS=

# Optional text-to-speech playback for completed Chatbot replies.
# The default adapter uses Volcengine Doubao TTS 2.0 through the V3 HTTP Chunked API.
# Keep the API key on the backend; never expose it through NEXT_PUBLIC_* variables.
# OPENCLASS_SPEECH_PROVIDER=volcengine
# VOLCENGINE_TTS_API_KEY=your_volcengine_speech_api_key
# VOLCENGINE_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v3/tts/unidirectional
# VOLCENGINE_TTS_RESOURCE_ID=seed-tts-2.0
# VOLCENGINE_TTS_SPEAKER=zh_female_vv_uranus_bigtts
# VOLCENGINE_TTS_SAMPLE_RATE=24000
# VOLCENGINE_TTS_SPEECH_RATE=0
# VOLCENGINE_TTS_TIMEOUT_SECONDS=30
